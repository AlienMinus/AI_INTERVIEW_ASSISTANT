{
  "manifest_version": 3,
  "name": "AI Interview Assistant",
  "description": "Practice interviews directly from your browser.",
  "version": "1.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/image.png"
      
    }
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  }
}
